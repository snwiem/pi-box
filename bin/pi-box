#!/usr/bin/env bash
set -euo pipefail

# -----------------------------------------------------------------------------
# pi-box — rootless Podman launcher for the pi coding agent
#
# Usage: pi-box <subcommand> [options]
# Run `pi-box help` or `pi-box run --help` for details.
# -----------------------------------------------------------------------------

PI_BOX_PROFILES_DIR="${HOME}/.pi-box"

# -----------------------------------------------------------------------------
# usage — print help and exit 0 (or let caller exit with a specific code)
# -----------------------------------------------------------------------------
usage() {
  cat <<EOF
Usage: pi-box <subcommand> [options]

Subcommands:
  run <profile> [options]         Launch a pi session in the named profile container
  list-sessions [<profile>]       List existing sessions (all profiles or one)

Run options:
  --force-rebuild                 Force a fresh profile image build ignoring cache
  --session <name>                Name the session (auto UUID when omitted)
  --project-root <path>           Project root directory (default: \$PWD)
  -v <host:container>             Mount a host path into the container (repeatable)

List-sessions options:
  [<profile>]                     Scope listing to a single profile (default: all)
  --project-root <path>           Project root directory (default: \$PWD)

Examples:
  pi-box run myprofile
  pi-box run myprofile --session my-feature -v \$(pwd):/workspace
  pi-box run myprofile -v \$(pwd):/workspace -v /data:/data:ro
  pi-box list-sessions
  pi-box list-sessions myprofile
  pi-box list-sessions --project-root ~/projects/other
EOF
}

# -----------------------------------------------------------------------------
# generate_uuid
# Emit a random UUID.  Tries uuidgen first (Linux util-linux / macOS), then
# falls back to /proc/sys/kernel/random/uuid (Linux kernel ≥2.6), then fails
# with a clear error rather than silently producing a non-random identifier.
# -----------------------------------------------------------------------------
generate_uuid() {
  if command -v uuidgen > /dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  elif [[ -r /proc/sys/kernel/random/uuid ]]; then
    cat /proc/sys/kernel/random/uuid
  else
    echo "error: cannot generate UUID: neither uuidgen nor /proc/sys/kernel/random/uuid is available" >&2
    exit 1
  fi
}

# -----------------------------------------------------------------------------
# sha256_file <path>
# Print the SHA-256 hex digest of a file.  Works on Linux (sha256sum) and
# macOS (shasum).
# -----------------------------------------------------------------------------
sha256_file() {
  local file="$1"
  if command -v sha256sum > /dev/null 2>&1; then
    sha256sum "$file" | cut -d' ' -f1
  elif command -v shasum > /dev/null 2>&1; then
    shasum -a 256 "$file" | cut -d' ' -f1
  else
    echo "error: no SHA-256 utility found (need sha256sum or shasum)" >&2
    exit 1
  fi
}

# -----------------------------------------------------------------------------
# cmd_run — implement the `run` subcommand
# -----------------------------------------------------------------------------
cmd_run() {
  # --------------------------------------------------------------------------
  # Argument parsing (TASK-02-01)
  # Parse ALL flags for the full launcher now so parsing need not be revisited
  # in FEAT-03/04/05/06.  Variables not yet wired up are parsed but unused.
  # --------------------------------------------------------------------------
  local PROFILE=""
  local FORCE_REBUILD=false
  local SESSION=""
  local PROJECT_ROOT="${PWD}"
  local MOUNTS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force-rebuild)
        FORCE_REBUILD=true
        shift
        ;;
      --session)
        if [[ $# -lt 2 || -z "${2:-}" ]]; then
          echo "error: --session requires a non-empty value" >&2
          usage; exit 1
        fi
        SESSION="$2"
        shift 2
        ;;
      --project-root)
        if [[ $# -lt 2 || -z "${2:-}" ]]; then
          echo "error: --project-root requires a non-empty value" >&2
          usage; exit 1
        fi
        PROJECT_ROOT="$2"
        shift 2
        ;;
      -v)
        if [[ $# -lt 2 || -z "${2:-}" ]]; then
          echo "error: -v requires a value" >&2
          usage; exit 1
        fi
        MOUNTS+=("$2")
        shift 2
        ;;
      --*)
        echo "error: unknown flag: $1" >&2
        usage; exit 1
        ;;
      -*)
        echo "error: unknown flag: $1" >&2
        usage; exit 1
        ;;
      *)
        if [[ -z "${PROFILE}" ]]; then
          PROFILE="$1"
        else
          echo "error: unexpected argument: $1" >&2
          usage; exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "${PROFILE}" ]]; then
    echo "error: <profile> is required" >&2
    usage; exit 1
  fi

  if [[ ! "${PROFILE}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "error: invalid profile name '${PROFILE}': only a-z, A-Z, 0-9, _ and - are allowed" >&2
    exit 1
  fi

  # --------------------------------------------------------------------------
  # Profile directory resolution
  # Convention (PRD §8): ~/.pi-box/<profile>/
  # --------------------------------------------------------------------------
  local PROFILE_DIR="${PI_BOX_PROFILES_DIR}/${PROFILE}"
  if [[ ! -d "${PROFILE_DIR}" ]]; then
    echo "error: profile directory not found: ${PROFILE_DIR}" >&2
    echo "       Create it and add an optional container.yml to get started." >&2
    exit 1
  fi

  # --------------------------------------------------------------------------
  # Image build step (TASK-02-02)
  # Decision tree:
  #   1. No container.yml  → IMAGE=pi-box:base, skip build
  #   2. --force-rebuild   → always build
  #   3. image missing     → build
  #   4. container.yml SHA changed → build
  #   5. otherwise         → skip build, use existing image
  # --------------------------------------------------------------------------
  local IMAGE
  local CONTAINER_YML="${PROFILE_DIR}/container.yml"

  if [[ ! -f "${CONTAINER_YML}" ]]; then
    # No container.yml — fall back to base image, no build needed
    IMAGE="pi-box:base"
    echo "==> No container.yml found; using base image: ${IMAGE}"
    if [[ "${FORCE_REBUILD}" == true ]]; then
      echo "==> (--force-rebuild has no effect: no container.yml in profile directory)" >&2
    fi
  else
    IMAGE="pi-box-${PROFILE}:latest"
    local DO_BUILD=false

    if [[ "${FORCE_REBUILD}" == true ]]; then
      echo "==> --force-rebuild set; scheduling build of: ${IMAGE}"
      DO_BUILD=true
    elif ! podman image exists "${IMAGE}" 2>/dev/null; then
      echo "==> Image not found locally; scheduling build of: ${IMAGE}"
      DO_BUILD=true
    else
      # Staleness check: compare current SHA256 against label stored at build time
      local CURRENT_SHA
      CURRENT_SHA="$(sha256_file "${CONTAINER_YML}")"
      local STORED_SHA
      STORED_SHA="$(podman inspect \
        --format '{{ index .Labels "pi-box.container-yml-sha" }}' \
        "${IMAGE}" 2>/dev/null || true)"
      if [[ "${CURRENT_SHA}" != "${STORED_SHA}" ]]; then
        echo "==> container.yml changed (${CURRENT_SHA:0:12}… vs ${STORED_SHA:0:12}…); scheduling rebuild"
        DO_BUILD=true
      fi
    fi

    if [[ "${DO_BUILD}" == true ]]; then
      echo "==> Building profile image: ${IMAGE}"
      local BUILD_SHA
      BUILD_SHA="$(sha256_file "${CONTAINER_YML}")"
      if ! podman build \
          --label "pi-box.container-yml-sha=${BUILD_SHA}" \
          -f "${CONTAINER_YML}" \
          -t "${IMAGE}" \
          "${PROFILE_DIR}"; then
        echo "error: podman build failed for profile '${PROFILE}'" >&2
        exit 1
      fi
      echo "==> Build complete: ${IMAGE}"
    else
      echo "==> Profile image up to date: ${IMAGE}"
    fi
  fi

  # --------------------------------------------------------------------------
  # Container run invocation (TASK-02-03)
  # RUN_ARGS is an array so later features can append flags cleanly:
  #   FEAT-03 appends -v mount flags
  #   FEAT-04 appends profile config file mounts
  #   FEAT-05 appends session directory mount
  # exec replaces the shell process → correct signal propagation and exit code.
  # --------------------------------------------------------------------------
  local RUN_ARGS=(--rm -it)
  # FEAT-03: pass through user-supplied -v mounts
  for mount in "${MOUNTS[@]+${MOUNTS[@]}}"; do
    RUN_ARGS+=(-v "${mount}")
  done
  # FEAT-04: mount profile config files into the container (read-only).
  # Each entry is   <profile-path> → <container-path>
  # Only paths that exist in the profile directory are mounted; absent paths
  # are silently skipped so pi falls back to its own defaults.
  #
  # Container user is root (node:22-alpine, no USER set) → config root is
  # /root/.pi/agent/ inside the container.
  #
  # Mapping (validated against pi docs and local install):
  #   skills/          → /root/.pi/agent/skills/
  #   extensions/      → /root/.pi/agent/extensions/
  #   prompts/         → /root/.pi/agent/prompts/
  #   themes/          → /root/.pi/agent/themes/
  #   AGENTS.md        → /root/.pi/agent/AGENTS.md     (global; loaded for every cwd)
  #   APPEND_SYSTEM.md → /root/.pi/agent/APPEND_SYSTEM.md
  local -a PROFILE_MOUNTS=(
    "skills:/root/.pi/agent/skills"
    "extensions:/root/.pi/agent/extensions"
    "prompts:/root/.pi/agent/prompts"
    "themes:/root/.pi/agent/themes"
    "AGENTS.md:/root/.pi/agent/AGENTS.md"
    "APPEND_SYSTEM.md:/root/.pi/agent/APPEND_SYSTEM.md"
  )
  for entry in "${PROFILE_MOUNTS[@]}"; do
    local src="${PROFILE_DIR}/${entry%%:*}"
    local dst="${entry#*:}"
    if [[ -e "${src}" ]]; then
      RUN_ARGS+=(-v "${src}:${dst}:ro")
      echo "==> Mounting profile config: ${entry%%:*} → ${dst}"
    fi
  done
  # FEAT-05: session directory resolution, creation, and mount.
  #
  # TASK-05-01: resolve project root and construct the session directory path.
  #   PROJECT_ROOT is already set from argument parsing (defaults to $PWD or
  #   the value of --project-root). Resolve it to an absolute path here using
  #   $(cd … && pwd) for portability (avoids requiring realpath on all platforms).
  if [[ ! -d "${PROJECT_ROOT}" ]]; then
    echo "error: --project-root path does not exist: ${PROJECT_ROOT}" >&2
    exit 1
  fi
  PROJECT_ROOT="$(cd "${PROJECT_ROOT}" && pwd)"
  # FEAT-06: resolve SESSION_ID from --session or generate a UUID fallback.
  # Validate session name: allow alphanumerics, hyphens, underscores, dots, and
  # forward slashes only — consistent with PROFILE validation and prevents
  # path-traversal via sequences like ../../etc.
  if [[ -n "${SESSION}" && ! "${SESSION}" =~ ^[a-zA-Z0-9._/-]+$ ]]; then
    echo "error: invalid session name '${SESSION}': only a-z, A-Z, 0-9, ., _, - and / are allowed" >&2
    exit 1
  fi
  if [[ "${SESSION}" == *".."* ]]; then
    echo "error: session name must not contain '..': ${SESSION}" >&2
    exit 1
  fi
  local SESSION_ID
  if [[ -n "${SESSION}" ]]; then
    SESSION_ID="${SESSION}"
  else
    SESSION_ID="$(generate_uuid)"
    echo "==> Session: ${SESSION_ID}"
  fi
  local SESSION_DIR="${PROJECT_ROOT}/.pi-box/${PROFILE}/sessions/${SESSION_ID}"
  mkdir -p "${SESSION_DIR}"
  echo "==> Session directory: ${SESSION_DIR}"
  RUN_ARGS+=(-v "${SESSION_DIR}:/pi-session")

  # TASK-05-02: redirect pi session storage to /pi-session inside the container.
  #
  # Precedence (from pi docs): --session-dir > PI_CODING_AGENT_SESSION_DIR > sessionDir
  # Using the env var avoids generating and mounting an extra settings.json file,
  # keeps the base image clean, and works even if the user has their own
  # settings.json in the profile directory.
  RUN_ARGS+=(-e "PI_CODING_AGENT_SESSION_DIR=/pi-session")

  exec podman run "${RUN_ARGS[@]}" "${IMAGE}" pi
}

# -----------------------------------------------------------------------------
# cmd_list_sessions — list sessions stored under <project-root>/.pi-box/
#
# Usage: list-sessions [<profile>] [--project-root <path>]
# -----------------------------------------------------------------------------
cmd_list_sessions() {
  local PROFILE_FILTER=""
  local PROJECT_ROOT="${PWD}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-root)
        if [[ $# -lt 2 || -z "${2:-}" ]]; then
          echo "error: --project-root requires a non-empty value" >&2
          usage; exit 1
        fi
        PROJECT_ROOT="$2"
        shift 2
        ;;
      --*)
        echo "error: unknown flag: $1" >&2
        usage; exit 1
        ;;
      *)
        if [[ -z "${PROFILE_FILTER}" ]]; then
          PROFILE_FILTER="$1"
        else
          echo "error: unexpected argument: $1" >&2
          usage; exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ ! -d "${PROJECT_ROOT}" ]]; then
    echo "error: --project-root path does not exist: ${PROJECT_ROOT}" >&2
    exit 1
  fi
  PROJECT_ROOT="$(cd "${PROJECT_ROOT}" && pwd)"

  # Validate the profile filter if provided (consistent with PROFILE validation
  # in cmd_run and prevents path-traversal via e.g. '../../etc').
  if [[ -n "${PROFILE_FILTER}" && ! "${PROFILE_FILTER}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "error: invalid profile name '${PROFILE_FILTER}': only a-z, A-Z, 0-9, _ and - are allowed" >&2
    exit 1
  fi

  local SESSIONS_BASE="${PROJECT_ROOT}/.pi-box"

  # Collect (profile, session, mtime) tuples from the filesystem.
  # Layout: .pi-box/<profile>/sessions/<session-id>/
  # Use three parallel arrays instead of a delimited string so that session
  # names containing arbitrary characters (e.g. '.', '-') are safe.
  local -a ROW_PROFILE=()
  local -a ROW_SESSION=()
  local -a ROW_MTIME=()
  local found=false

  # Determine which profile directories to scan.
  local -a PROFILE_DIRS=()
  if [[ -n "${PROFILE_FILTER}" ]]; then
    PROFILE_DIRS=("${SESSIONS_BASE}/${PROFILE_FILTER}")
  else
    # Glob all profile directories; skip gracefully if none exist.
    if [[ -d "${SESSIONS_BASE}" ]]; then
      while IFS= read -r -d '' pdir; do
        PROFILE_DIRS+=("${pdir}")
      done < <(find "${SESSIONS_BASE}" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
    fi
  fi

  for pdir in "${PROFILE_DIRS[@]+${PROFILE_DIRS[@]}}"; do
    local pname
    pname="$(basename "${pdir}")"
    local sbase="${pdir}/sessions"
    [[ -d "${sbase}" ]] || continue

    while IFS= read -r -d '' sdir; do
      local sname
      sname="$(basename "${sdir}")"
      # Last-modified time of the session directory itself.
      # Use printf '%(%Y-%m-%d %H:%M)T' with stat mtime seconds for portability.
      local mtime
      if stat --version > /dev/null 2>&1; then
        # GNU stat (Linux)
        mtime="$(stat -c '%y' "${sdir}" | cut -c1-16)"
      else
        # BSD stat (macOS)
        mtime="$(stat -f '%Sm' -t '%Y-%m-%d %H:%M' "${sdir}")"
      fi
      ROW_PROFILE+=("${pname}")
      ROW_SESSION+=("${sname}")
      ROW_MTIME+=("${mtime}")
      found=true
    done < <(find "${sbase}" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
  done

  if [[ "${found}" == false ]]; then
    if [[ -n "${PROFILE_FILTER}" ]]; then
      echo "No sessions found for profile '${PROFILE_FILTER}' under ${PROJECT_ROOT}/.pi-box/"
    else
      echo "No sessions found under ${PROJECT_ROOT}/.pi-box/"
    fi
    exit 0
  fi

  # Print table with fixed-width columns.
  printf '%-20s  %-36s  %s\n' 'PROFILE' 'SESSION' 'LAST MODIFIED'
  printf '%-20s  %-36s  %s\n' '-------' '-------' '-------------'
  local i
  for (( i=0; i<${#ROW_PROFILE[@]}; i++ )); do
    printf '%-20s  %-36s  %s\n' "${ROW_PROFILE[i]}" "${ROW_SESSION[i]}" "${ROW_MTIME[i]}"
  done
}

# -----------------------------------------------------------------------------
# Main dispatch
# -----------------------------------------------------------------------------
if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  run)
    shift
    cmd_run "$@"
    ;;
  list-sessions)
    shift
    cmd_list_sessions "$@"
    ;;
  help|--help|-h)
    usage
    exit 0
    ;;
  *)
    echo "error: unknown subcommand: $1" >&2
    usage
    exit 1
    ;;
esac
